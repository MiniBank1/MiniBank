<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard</title>
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <header class="header">
        <a href="/Dashboard/Index" class="logo">Nova Bank<span class="animate" style="--i:1;"></span></a>

        <nav class="navbar">
            <a href="/Home/Index">Home</a>
            <a href="/Dashboard/Index">Dashboard</a>
            <a href="/Account/Index">Accounts</a>
            <a href="/Transfer/Transfer">Transfer</a>
            <span class="animate" style="--i:2;"></span>
        </nav>

        <div class="header-right" style="display: flex; align-items: center; gap: 20px; position: relative;">
            <a href="#" class="nav-notification" data-bs-toggle="modal" data-bs-target="#notificationModal"
               style="color: #fff; font-size: 22px; text-decoration: none; position: relative;">
                <i class="ri-notification-fill"></i>
                <span id="notification-badge" style="display: none; position: absolute; top: -5px; right: -8px; background: #ff4757; color: white; font-size: 10px; font-weight: bold; padding: 2px 6px; border-radius: 50%; border: 2px solid #01003f;">
                    0
                </span>
            </a>

            <a href="/Auth/Login" class="btn-logout-minimal" title="Log Out" style="color: #fff; font-size: 24px; text-decoration: none;">
                <i class="ri-door-open-line"></i>
                <span class="animate" style="--i:3;"></span>
            </a>
        </div>
    </header>
    <div>
        @RenderBody()
    </div>
    @Html.AntiForgeryToken()

    <div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: linear-gradient(135deg, #1e1e2f, #2c2c54); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.5);">
                <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding: 20px;">
                    <h5 class="modal-title" style="color: white; font-weight: 700; letter-spacing: 0.5px;">Recent Notifications</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="notificationList" style="max-height: 450px; overflow-y: auto; padding: 10px 25px;">
                    <div class="text-center p-5">
                        <div class="spinner-border" style="color: #42c1e8;" role="status"></div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.05); padding: 10px;">
                    <button type="button" class="btn btn-sm w-100" data-bs-dismiss="modal" style="color: #aaa; font-size: 12px; border: none;">Close</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>

@Html.AntiForgeryToken()

<div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background: linear-gradient(135deg, #1e1e2f, #2c2c54); border: 1px solid rgba(255,255,255,0.1); border-radius: 15px;">
            <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                <h5 class="modal-title" style="color: white; font-weight: 700;">Notifications</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="notificationList" style="max-height: 400px; overflow-y: auto; padding: 15px 25px;">
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        updateNotificationBadgeCount();

        const currentPath = window.location.pathname.toLowerCase();
        const navLinks = document.querySelectorAll('.navbar a');

        navLinks.forEach(link => {
            const linkPath = link.getAttribute('href').toLowerCase();

            // 🔥 GELİŞMİŞ ACTIVE LOGIC
            if (linkPath === '/home/index') {
                if (currentPath === '/' || currentPath === '/home/index') {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            }
            else if (currentPath.startsWith(linkPath)) {
                link.classList.add('active');
            }
            else {
                link.classList.remove('active');
            }
        });

        const modalElement = document.getElementById('notificationModal');

        if (modalElement) {
            modalElement.addEventListener('show.bs.modal', function () {
                loadUnreadNotifications();
            });
        }
    });


    // ================= BADGE =================
    function updateNotificationBadgeCount(manualCount) {
        const badge = document.getElementById('notification-badge');
        if (!badge) return;

        if (manualCount !== undefined) {
            applyBadgeStyle(badge, manualCount);
            return;
        }

        fetch('/Notification/GetUnreadCount?t=' + new Date().getTime())
            .then(res => {
                if (!res.ok) throw new Error('Unread count alınamadı');
                return res.json();
            })
            .then(count => {
                applyBadgeStyle(badge, count);
            })
            .catch(err => console.error('Badge Hatası:', err));
    }

    function applyBadgeStyle(badge, count) {
        if (count > 0) {
            badge.innerText = count > 9 ? '9+' : count;
            badge.style.display = 'block';
        } else {
            badge.style.display = 'none';
        }
    }


    // ================= NOTIFICATIONS =================
    function loadUnreadNotifications() {
        const listContainer = document.getElementById('notificationList');
        if (!listContainer) return;

        listContainer.innerHTML = `
            <div class="text-center p-4">
                <div class="spinner-border" style="color: #42c1e8;" role="status"></div>
            </div>
        `;

        fetch('/Notification/GetUnreadNotifications?t=' + new Date().getTime())
            .then(res => {
                if (!res.ok) throw new Error('Bildirimler alınamadı');
                return res.json();
            })
            .then(data => {
                if (!data || data.length === 0) {
                    listContainer.innerHTML = `
                        <div class="text-center p-4" style="color: #bbb;">
                            Okunmamış bildiriminiz yok.
                        </div>
                    `;
                    return;
                }

                listContainer.innerHTML = data.map(n => `
                    <div id="noti-${n.notificationId}"
                         style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 14px; margin-bottom: 12px; transition: .3s;">

                        <div style="color: white; font-size: 14px; font-weight: 500; margin-bottom: 6px;">
                            ${escapeHtml(n.message)}
                        </div>

                        <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
                            <small style="color:#aaa;">
                                ${formatDate(n.createdAt)}
                            </small>

                            <button onclick="markAsReadAndRemove(${n.notificationId})"
                                    style="background: transparent; border: 1px solid #42c1e8; color: #42c1e8; border-radius: 50%; width: 26px; height: 26px; cursor: pointer;">
                                <i class="ri-check-line"></i>
                            </button>
                        </div>
                    </div>
                `).join('');
            })
            .catch(err => {
                console.error('Notification list error:', err);
                listContainer.innerHTML = `
                    <div class="text-center p-4" style="color: #ffb3b3;">
                        Bildirimler yüklenirken hata oluştu.
                    </div>
                `;
            });
    }


    // ================= MARK AS READ =================
    function markAsReadAndRemove(id) {
        const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        if (!tokenElement) return;

        const formData = new FormData();
        formData.append('notificationId', id);

        fetch('/Notification/MarkAsRead', {
            method: 'POST',
            headers: {
                'RequestVerificationToken': tokenElement.value
            },
            body: formData
        })
            .then(res => {
                if (!res.ok) throw new Error('Okundu işaretleme başarısız');

                const element = document.getElementById(`noti-${id}`);
                if (element) {
                    element.style.opacity = '0';
                    element.style.transform = 'translateX(10px)';

                    setTimeout(() => {
                        element.remove();
                        updateNotificationBadgeCount();

                        const remaining = document.querySelectorAll('[id^="noti-"]');
                        if (remaining.length === 0) {
                            const listContainer = document.getElementById('notificationList');
                            if (listContainer) {
                                listContainer.innerHTML = `
                                <div class="text-center p-4" style="color: #bbb;">
                                    Okunmamış bildiriminiz yok.
                                </div>
                            `;
                            }
                        }
                    }, 300);
                } else {
                    updateNotificationBadgeCount();
                }
            })
            .catch(err => console.error('MarkAsRead error:', err));
    }


    // ================= HELPERS =================
    function formatDate(dateString) {
        const date = new Date(dateString);
        return date.toLocaleString('tr-TR');
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.innerText = text;
        return div.innerHTML;
    }
</script>